{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steam Shadow Launcher",
  "version": "0.2.1",
  "identifier": "io.kilocode.steamshadow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Steam Shadow Launcher",
        "width": 760,
        "height": 520,
        "minWidth": 760,
        "minHeight": 520,
        "maxWidth": 760,
        "maxHeight": 520,
        "resizable": false,
        "decorations": false,
        "dragDropEnabled": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
